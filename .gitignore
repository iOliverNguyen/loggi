# Built binary
/loggi

# Go
*.test
*.out
coverage.txt

# Embedded SPA build output (regenerated by `cd web && npm run build`).
# The directory itself is kept via .gitkeep so //go:embed all:spa works on
# fresh clones; the embedded handler falls back to a placeholder page when
# index.html is absent.
/internal/app/spa/index.html
/internal/app/spa/assets/

# Web (Svelte / Vite / pnpm)
/web/node_modules/
/web/dist/
/web/.svelte-kit/
/web/.vite/
# Lockfiles from other package managers (we use pnpm)
/web/package-lock.json
/web/yarn.lock

# loggi local config overrides (per loggi's own config precedence design)
*.local.toml

# OS
.DS_Store
Thumbs.db

# Editor scratch
*.swp
*.swo
*~
